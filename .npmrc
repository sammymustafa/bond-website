# Cloudflare Pages runs `npx @cloudflare/next-on-pages@1`, which fresh-installs
# the build tool. wrangler >= 4.112 declares a peer dependency on
# @cloudflare/workers-types@^5 that conflicts with @cloudflare/next-on-pages
# (which expects ^4), so a strict install fails with ERESOLVE. Legacy peer-deps
# resolution restores the pre-npm-7 behavior and lets the build proceed.
legacy-peer-deps=true
